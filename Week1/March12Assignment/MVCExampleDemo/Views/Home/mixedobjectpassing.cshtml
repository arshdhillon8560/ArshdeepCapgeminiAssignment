@model MVCExampleDemo.Models.EmpdeptViewModel

@{
    ViewData["Title"] = "mixedobjectpassing";
}

<h2>Employee Details</h2>

<h1>@Model.emp.EmpName</h1>
<div>
    <img src="@Model.emp.ImageUrl" alt="@Model.emp.EmpName" width="300" height="300" />
</div>

<div>
    <h2>Employee</h2>
    <p>Lorem Ipsum is a standard placeholder text used in design and publishing to visualize layouts without distracting from content.</p>
    <h2>@Model.emp.Salary</h2>
    <h2><a asp-action="collectionofobjectspassing">back to list</a></h2>

</div>

<br />

<h2>Department List</h2>

<table border="1" cellpadding="10">
    <tr>
        <th>Department ID</th>
        <th>Department Name</th>
    </tr>

    @foreach (var dept in Model.deptlist)
    {
        <tr>
            <td>@dept.DeptID</td>
            <td>@dept.DeptName</td>
        </tr>
    }
</table>

<br />

<h3>Current Date : @Model.date</h3>

