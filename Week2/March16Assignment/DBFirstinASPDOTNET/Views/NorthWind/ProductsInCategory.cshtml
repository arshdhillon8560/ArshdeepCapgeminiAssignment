@model IEnumerable<DBFirstinASPDOTNET.Models.ProdCat>

@{
    ViewData["Title"] = "ProductsInCategory";
}

<div class="container mt-4">

    <!-- Header + Search -->
    <div class="card shadow-sm p-4 mb-4">
        <div class="row align-items-center">

            <div class="col-md-6">
                <h3 class="fw-bold text-primary mb-0">Products in Category</h3>
            </div>

            <div class="col-md-6">
                <form method="get" action="/NorthWind/ProductsInCategory">
                    <div class="input-group">
                        <input type="text" id="category" name="categoryname"
                               class="form-control" placeholder="Enter category name..." />

                        <button type="submit" id="Searchproducts"
                                class="btn btn-primary">
                            🔍 Search
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>

    <!-- Result Section -->
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center shadow-sm">
            <h5 class="mb-0">⚠️ No Products Found</h5>
        </div>
    }
    else
    {
        <div class="card shadow-sm p-3">
            <div class="table-responsive">
                <table id="prodlist" class="table table-hover table-striped align-middle text-center">
                    
                    <thead class="table-dark">
                        <tr>
                            <th>Product Name</th>
                            <th>Category Name</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var prod in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@prod.prodname</td>
                                <td>
                                    <span class="badge bg-success px-3 py-2">
                                        @prod.catname
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    }

</div>