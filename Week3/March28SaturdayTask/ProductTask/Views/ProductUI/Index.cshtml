@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Product Management</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.2/dist/quartz/bootstrap.min.css" rel="stylesheet">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>

<body>

    <!-- Header -->
    <div class="bg-primary text-white p-3 text-center">
        <h2>Product Management</h2>
    </div>

    <div class="container mt-4">

        <a href="/ProductUI/Create" class="btn btn-success mb-3">Add New Product</a>

        <h3 class="mb-3">Product Data</h3>

        <!-- Search -->
        <div class="mb-3 d-flex">
            <input type="text" id="searchText" class="form-control me-2" placeholder="Search by name" />
            <button id="btnSearch" class="btn btn-primary">Search</button>
        </div>

        <!-- Table -->
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Category</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="productTableBody"></tbody>
        </table>

    </div>

    <!-- Script -->
    <script>

        function loadProducts(search = "") {
        $.ajax({
        url: `/api/Product`,
        type: "GET",
        success: function (data) {

        let rows = "";

        // ✅ Search filter
        if (search) {
        data = data.filter(p =>
        p.name.toLowerCase().includes(search.toLowerCase())
        );
        }

        if (data.length === 0) {
        rows = "<tr><td colspan='5' class='text-center'>No records found</td></tr>";
        } else {

        $.each(data, function (i, prod) {

        rows += `
        <tr>
        <td>${prod.id}</td>
        <td>${prod.name}</td>
        <td>${prod.price}</td>
        <td>${prod.category}</td>
        <td>
        <a href="/ProductUI/Details?id=${prod.id}" class="btn btn-sm btn-info">Details</a>
        <a href="/ProductUI/Edit?id=${prod.id}" class="btn btn-sm btn-warning">Edit</a>
        <a href="/ProductUI/Delete?id=${prod.id}" class="btn btn-sm btn-danger">Delete</a>
        </td>
        </tr>`;
        });
        }

        $("#productTableBody").html(rows);
        },
        error: function () {
        alert("Failed to load data.");
        }
        });
        }

        function reload() {
        const search = $("#searchText").val();
        loadProducts(search);
        }

        $(document).ready(function () {

        // Initial load
        reload();

        // Search button click
        $("#btnSearch").click(function () {
        reload();
        });

   
        $("#searchText").keypress(function (e) {
        if (e.which === 13) {
        e.preventDefault();
        reload();
        }
        });

        });

    </script>

</body>
</html>