@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Delete Product</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.2/dist/quartz/bootstrap.min.css" rel="stylesheet">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>

<body>

    <!-- Header -->
    <div class="bg-danger text-white p-3 text-center">
        <h2>Delete Product</h2>
    </div>

    <div class="container mt-4">

        <div class="card mx-auto shadow text-center" style="width: 450px; border-radius: 15px;">

            <div class="card-header bg-danger text-white">
                Delete Confirmation
            </div>

            <div class="card-body">

                <h4 id="productName">Loading...</h4>
                <p><strong>ID:</strong> <span id="productId"></span></p>
                <p><strong>Price:</strong> ₹ <span id="productPrice"></span></p>
                <p><strong>Category:</strong> <span id="productCategory"></span></p>

                <div class="mt-3">
                    <button class="btn btn-danger" id="btnDelete">Confirm Delete</button>
                    <a href="/ProductUI/Index" class="btn btn-secondary">Cancel</a>
                </div>

            </div>

        </div>

    </div>

    <script>

        $(document).ready(function () {

        const params = new URLSearchParams(window.location.search);
        const id = params.get("id");

        if (!id) {
        alert("No product ID provided");
        return;
        }

        // ✅ Load product details
        $.ajax({
        url: `/api/Product/${id}`,
        type: "GET",
        success: function (prod) {

        if (!prod) {
        alert("Product not found");
        return;
        }

        $("#productName").text(prod.name);
        $("#productId").text(prod.id);
        $("#productPrice").text(prod.price);
        $("#productCategory").text(prod.category);
        },
        error: function () {
        alert("Failed to load product.");
        }
        });

        // ✅ Delete product
        $("#btnDelete").click(function () {

        if (confirm("Are you sure you want to delete this product?")) {

        $.ajax({
        url: `/api/Product/${id}`,
        type: "DELETE",
        success: function () {
        alert("Product deleted successfully.");
        window.location.href = "/ProductUI/Index";
        },
        error: function (xhr) {
        alert("Error: " + xhr.responseText);
        }
        });

        }

        });

        });

    </script>

</body>
</html>