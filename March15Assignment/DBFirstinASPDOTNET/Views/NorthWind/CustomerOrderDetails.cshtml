@model IEnumerable<DBFirstinASPDOTNET.Models.Order>

@{
    ViewData["Title"] = "CustomerOrderDetails";
}

<h1>CustomerOrderDetails</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Order ID</th>
            <th>Order Date</th>
            
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.OrderId</td>
                <td>@order.OrderDate</td>
              
            </tr>
        }
    </tbody>
</table>